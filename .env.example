# Server
PORT=5096
NODE_ENV=development

# Auth (base64-encoded super admin login)
ADMIN_EMAIL_MASKED=
ADMIN_PASSWORD_MASKED=
ADMIN_SESSION_SECRET=change_me_in_production_use_long_random_string

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=

# Firebase project config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Firestore Admin — service account (Firebase Console > Service Accounts > Generate private key)
# Option A: full JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: base64-encoded JSON file
# FIREBASE_SERVICE_ACCOUNT_BASE64=
# Option C: individual fields
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
